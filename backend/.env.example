# BroDoc — Environment Variables
# ================================
# Copy this file to .env and fill in real values.
# NEVER commit the actual .env file to git.
# This .env.example IS safe to commit (it has no real secrets).

# Application
APP_NAME="BroDoc — Async Document Processing System"
APP_VERSION="1.0.0"
DEBUG=true

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://brodoc_user:brodoc_pass@localhost:5432/brodoc_db
SYNC_DATABASE_URL=postgresql+psycopg2://brodoc_user:brodoc_pass@localhost:5432/brodoc_db

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_PUBSUB_CHANNEL=brodoc:progress

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_BYTES=20971520

# CORS
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# Security
SECRET_KEY=brodoc-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
